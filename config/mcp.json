{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      },
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "octocode": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "octocode-mcp"
      ],
      "enabled": true
    },
    "gh-grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "agent-browser": {
      "type": "local",
      "command": [
        "agent-browser",
        "mcp"
      ],
      "enabled": true
    },
    "caveman": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "caveman-mcp",
        "caveman-mcp"
      ],
      "enabled": false
    }
  }
}